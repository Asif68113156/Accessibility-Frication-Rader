# ─────────────────────────────────────────────────────────────
#  AccessAble India — Environment Configuration
#  Copy this file to ".env" and fill in the values.
#  NEVER commit your real .env file to Git.
# ─────────────────────────────────────────────────────────────

# Django Core
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=*

# ─────────────────────────────────────────────────────────────
# EMAIL — Development (console, prints to terminal)
# ─────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# ─────────────────────────────────────────────────────────────
# EMAIL — Production (real Gmail SMTP)
# Step 1: Enable 2-Factor Authentication on your Gmail account.
# Step 2: Go to https://myaccount.google.com/apppasswords
# Step 3: Create an App Password for "Mail" → copy the 16-char code.
# Step 4: Paste it below and switch the EMAIL_BACKEND line.
# ─────────────────────────────────────────────────────────────
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=yourgmail@gmail.com
# EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
# DEFAULT_FROM_EMAIL=AccessAble India <yourgmail@gmail.com>
